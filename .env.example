# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Server
PORT=3000

# Render.com deployment (leave blank for local dev; set to your Render URL in production)
# Example: https://shopbot.onrender.com
RENDER_URL=

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Remove.bg API (free tier: 50 credits/month at remove.bg)
REMOVE_BG_API_KEY=your_remove_bg_api_key_here

# Stability AI (multi-angle image generation — platform.stability.ai)
STABILITY_API_KEY=your_stability_api_key_here

# Supabase (use the service_role key — never expose this publicly)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Amazon SP-API (Login with Amazon credentials + seller info)
# Get these from sellercentral.amazon.in → Apps & Services → Develop Apps
AMAZON_LWA_CLIENT_ID=amzn1.application-oa2-client.xxxx
AMAZON_LWA_CLIENT_SECRET=your_lwa_client_secret_here
AMAZON_LWA_REFRESH_TOKEN=Atzr|your_refresh_token_here
AMAZON_SELLER_ID=your_seller_id_here
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV

# Flipkart Seller API
# Get these from seller.flipkart.com → Account → Developer Access
FLIPKART_CLIENT_ID=your_flipkart_client_id_here
FLIPKART_CLIENT_SECRET=your_flipkart_client_secret_here
